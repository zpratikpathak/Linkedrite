# LinkedRite SaaS Application Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================
# Default Admin Account (Optional)
# ===========================
# Admin account is automatically created/updated on first request after server startup
# The password will ALWAYS be updated to match what's here
# WARNING: Use strong passwords in production!
# ADMIN_EMAIL=admin@linkedrite.com
# ADMIN_PASSWORD=change-this-secure-password
# ADMIN_FIRST_NAME=Admin
# ADMIN_LAST_NAME=User

# ===========================
# Database Configuration
# ===========================
# Option 1: Use DATABASE_URL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/linkedrite
# DATABASE_URL=mysql://username:password@localhost:3306/linkedrite
# DATABASE_URL=sqlite:///path/to/db.sqlite3

# Option 2: Use individual database settings
# DB_ENGINE=django.db.backends.postgresql
# DB_ENGINE=django.db.backends.mysql
# DB_ENGINE=django.db.backends.sqlite3  (default)
# DB_NAME=linkedrite
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432  # 5432 for PostgreSQL, 3306 for MySQL

# If no database settings are provided, SQLite will be used with db.sqlite3

# ===========================
# AI Provider Configuration
# ===========================
# Choose which AI provider to use: "azure" or "google"
AI_PROVIDER=google

# ===========================
# Google Gemini API Configuration
# ===========================
GOOGLE_API_KEY=your-google-gemini-api-key
GOOGLE_MODEL=gemini-3-flash-preview

# ===========================
# Azure OpenAI API Configuration
# ===========================
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_API_ENDPOINT=https://your-resource.openai.azure.com/
API_VERSION=2023-12-01-preview
DEPLOYMENT_MODEL=your-deployment-model-name

# ===========================
# Email Configuration (SMTP)
# ===========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=LinkedRite <noreply@linkedrite.com>

# ===========================
# Redis Configuration (Optional)
# ===========================
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=your-redis-password

# Cache Configuration (optional - uses Redis if configured)
# CACHE_TTL=300  # Cache timeout in seconds (default: 300)
# REDIS_SESSION_BACKEND=True  # Use Redis for session storage (default: False)

# ===========================
# Optional Settings
# ===========================
# Site URL (used for CSRF trusted origins)
# SITE_URL=http://localhost:8000

# Additional CSRF trusted origins (comma-separated)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Enable HTTPS security settings in production
# USE_HTTPS=True
